{
  "name": "auk-desktop",
  "private": true,
  "version": "26.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src",
    "lint:ts": "vue-tsc --noEmit -p tsconfig.lint.json",
    "lintfix": "eslint --fix src",
    "prod-lint": "cross-env AUK_LINT_FOR_PROD=true pnpm run lint",
    "do-lint": "pnpm run prod-lint",
    "do-typecheck": "pnpm run lint:ts",
    "do-lintfix": "pnpm run lintfix"
  },
  "dependencies": {
