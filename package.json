{
  "name": "auk-app",
  "version": "3.0.1",
  "description": "Open source API development ecosystem - Local First Edition",
  "author": "Mamahuhu (support@mamahuhu.io)",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "dev": "pnpm --filter @auk/common dev",
    "dev:desktop": "pnpm --filter auk-desktop dev",
    "check:workspace-scripts": "node scripts/check-workspace-scripts.mjs",
    "generate": "pnpm -r do-build-prod",
    "lint": "pnpm -r do-lint",
    "typecheck": "pnpm -r do-typecheck",
    "lintfix": "pnpm -r do-lintfix",
    "pre-commit": "pnpm run check:workspace-scripts && pnpm -r do-lint && pnpm -r do-typecheck",
    "test": "pnpm -r do-test",
    "generate-ui": "pnpm run generate",
    "bump": "node scripts/bump-desktop-version.mjs",
    "tauri": "cross-env NODE_OPTIONS=--max-old-space-size=8192 pnpm --filter auk-desktop tauri",
    "cargo": "bash scripts/cargo-all.sh",
    "verify:cli-e2e:online": "bash scripts/verify-cli-e2e-online.sh"
  },
  "workspaces": [
    "./packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.3.1",
    "@auk/ui": "workspace:^",
    "@types/node": "24.10.1",
    "cross-env": "10.1.0",
    "http-server": "14.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.7"
  },
  "pnpm": {
    "overrides": {
      "body-parser": "2.2.1",
      "cross-spawn": "7.0.6",
      "form-data": "4.0.4",
      "glob@<11.1.0": "11.1.0",
      "vue": "3.5.27",
      "ws": "8.17.1"
    },
    "onlyBuiltDependencies": [
      "@import-meta-env/unplugin",
      "@parcel/watcher",
      "@swc/core",
      "canvas",
      "core-js",
      "esbuild",
      "isolated-vm",
      "vue-demi"
    ]
  }
}
