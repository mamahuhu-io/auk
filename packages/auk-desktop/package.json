    "globals": "16.5.0",
    "postcss": "8.5.6",
    "sass": "1.97.2",
    "tailwindcss": "3.4.16",
    "typescript": "5.9.3",
    "unplugin-fonts": "1.4.0",
    "unplugin-icons": "22.5.0",
    "unplugin-vue-components": "30.0.0",
    "vite": "7.3.1",
    "vite-plugin-html-config": "2.0.2",
    "vite-plugin-inspect": "11.3.3",
